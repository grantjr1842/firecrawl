          "editorMode": "code",
          "expr": "100 * (sum(rate(http_request_duration_seconds_count{route=~\"/(scrape|crawl|map|extract|batchScrape|search|deepResearch|generateLLMstxt|tokenUsage|creditUsage|queueStatus).*\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_request_duration_seconds_count{route=~\"/(scrape|crawl|map|extract|batchScrape|search|deepResearch|generateLLMstxt|tokenUsage|creditUsage|queueStatus).*\"}[5m])), 0.001))",
